<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Modifier Utilisateur</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <header><h1>Modifier Utilisateur</h1></header>
    <main class="catway-container">
        <section class="add-section">
            <h2>Modification de : <%= user.username %></h2>
            <% if (typeof error !== 'undefined' && error) { %><div class="error-message"><%= error %></div><% } %>
            <form action="/users/update/<%= user._id %>" method="POST">
                <input type="text" name="username" value="<%= user.username %>" required>
                <input type="email" name="email" value="<%= user.email %>" required>
                <input type="password" name="password" placeholder="Nouveau mot de passe">
                <div style="margin-top: 10px;">
                    <button type="submit" class="btn btn-ok">Enregistrer</button>
                    <a href="/users" class="btn btn-cancel">Annuler</a>
                </div>
            </form>
        </section>
    </main>
    <footer><a href="/dashboard">← Retour au Dashboard</a></footer>
</body>
</html>