<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Gestion des Réservations</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <header><h1>Gestion des Réservations</h1></header>

    <main class="catway-container">
        <% if (locals.error && error) { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <section class="add-section">
            <h3>Nouvelle Réservation</h3>
            <form action="/reservations/add" method="POST">
                <label for="catwayNumber">N° Catway :</label>
                <select name="catwayNumber" id="catwayNumber" required>
                    <option value="">-- Choisir un Catway --</option>
                    <% if (locals.catways) { catways.forEach(function(c) { %>
                        <option value="<%= c.catwayNumber %>">Catway n°<%= c.catwayNumber %> (<%= c.catwayState %>)</option>
                    <% }); } %>
                </select>

                <input type="text" name="clientName" placeholder="Nom Client" required>
                <input type="text" name="boatName" placeholder="Nom Bateau" required>
                <label for="startDate">Date de début :</label>
                <input type="date" id="startDate" name="startDate" required>
                <label for="endDate">Date de fin :</label>
                <input type="date" id="endDate" name="endDate" required>
                <button type="submit" class="btn btn-ok">Réserver</button>
            </form>
        </section>

        <table>
            <thead>
                <tr>
                    <th>N° Catway</th>
                    <th>Client</th>
                    <th>Bateau</th>
                    <th>Dates</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% reservations.forEach(function(res) { %>
                    <tr>
                        <td><%= res.catwayNumber %></td>
                        <td><%= res.clientName %></td>
                        <td><%= res.boatName %></td>
                        <td>
                            <%= res.startDate ? res.startDate.toLocaleDateString() : 'N/A' %> 
                            - 
                            <%= res.endDate ? res.endDate.toLocaleDateString() : 'N/A' %>
                        </td>
                        <td>
                            <a href="/reservations/edit/<%= res._id %>" class="btn btn-ok">Modifier</a>
                            <a href="/reservations/delete/<%= res._id %>" 
                               class="btn btn-cancel"
                               onclick="return confirm('Êtes-vous sûr de vouloir supprimer cette réservation ?');">
                               Supprimer
                            </a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </main>
    <footer><a href="/dashboard">← Retour au Dashboard</a></footer>
</body>
</html>