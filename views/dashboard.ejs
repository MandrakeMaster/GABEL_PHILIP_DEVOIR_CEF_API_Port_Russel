<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Tableau de bord - Port de Russel</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <header>
        <h1>Tableau de bord</h1>
        <p><%= userName %> - <%= email %> - <%= date %></p>
    </header>

    <main>
        <nav class="dashboard-nav">
            <a href="/catways">Gestion Catways</a>
            <a href="/reservations">Gestion Réservations</a>
            <a href="/users">Gestion Utilisateurs</a>
            <a href="/logout">Déconnexion</a>
        </nav>

        <section class="reservations-section">
            <h2>Réservations en cours</h2>
            <table id="res-table">
                <thead>
                    <tr>
                        <th>N° Catway</th>
                        <th>Client</th>
                        <th>Nom du bateau</th>
                        <th>Début</th>
                        <th>Fin</th>
                    </tr>
                </thead>
                <tbody id="res-body">
                    <!-- Les données sont chargées via fetch -->
                </tbody>
            </table>
        </section>
    </main>

    <script>
        fetch('/api/dashboard-data')
            .then(response => response.json())
            .then(data => {
                const body = document.getElementById('res-body');
                body.innerHTML = ''; // Nettoie le contenu initial
                data.forEach(res => {
                    const row = `<tr>
                        <td>${res.catwayNumber}</td>
                        <td>${res.clientName}</td>
                        <td>${res.boatName}</td>
                        <td>${new Date(res.startDate).toLocaleDateString()}</td>
                        <td>${new Date(res.endDate).toLocaleDateString()}</td>
                    </tr>`;
                    body.innerHTML += row;
                });
            })
            .catch(err => console.error('Erreur lors du chargement des données:', err));
    </script>

    <footer>
        <p>© 2026 - Port de Russel</p>
    </footer>
</body>
</html>