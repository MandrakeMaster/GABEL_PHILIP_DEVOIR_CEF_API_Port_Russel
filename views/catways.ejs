<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Gestion des Catways</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/special.css">
</head>
<body>

    <header>
        <h1>Gestion des Catways</h1>
    </header>

    <main class="catway-container">
        <section class="add-section">
            <h3>Ajouter un nouveau Catway</h3>
            <form action="/catways/add" method="POST">
                <input type="number" name="catwayNumber" placeholder="N°" required>
                <select name="catwayType">
                    <option value="short">Short</option>
                    <option value="long">Long</option>
                </select>
                <input type="text" name="catwayState" placeholder="État" required>
                <button type="submit">Ajouter</button>
            </form>
        </section>

        <table>
            <thead>
                <tr>
                    <th>N°</th>
                    <th>Type</th>
                    <th>État</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% catways.forEach(function(cat) { %>
                    <!-- Identifiant unique pour chaque ligne -->
                    <tr id="row-<%= cat._id %>">
                        <td><%= cat.catwayNumber %></td>
                        <td><%= cat.catwayType %></td>
                        <td>
                            <% if (editId == cat._id) { %>
                                <form action="/catways/updateState/<%= cat._id %>" method="POST" style="display:inline;">
                                    <input type="text" name="catwayState" value="<%= cat.catwayState %>" required>
                                    <button type="submit">OK</button>
                                </form>
                            <% } else { %>
                                <%= cat.catwayState %>
                                <!-- L'ancre #row-id permet de rester sur la ligne -->
                                <a href="/catways?editId=<%= cat._id %>#row-<%= cat._id %>" style="font-size: 0.8em; margin-left: 10px;">(Modifier)</a>
                            <% } %>
                        </td>
                        <td>
                            <a href="/catways/delete/<%= cat._id %>" onclick="return confirm('Confirmer la suppression ?')">Supprimer</a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </main>

    <footer>
        <a href="/dashboard">← Retour au Dashboard</a>
    </footer>

</body>
</html>