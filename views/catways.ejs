<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Gestion des Catways</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <header><h1>Gestion des Catways</h1></header>

    <main class="catway-container">
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <section class="add-section">
            <h3>Ajouter un nouveau Catway</h3>
            <form action="/catways/add" method="POST">
                <input type="number" name="catwayNumber" placeholder="N°" required>
                <select name="catwayType">
                    <option value="short">Short</option>
                    <option value="long">Long</option>
                </select>
                <input type="text" name="catwayState" placeholder="État" required>
                <button type="submit" class="btn btn-ok">Ajouter</button>
            </form>
        </section>

        <table>
            <thead>
                <tr>
                    <th>N°</th>
                    <th>Type</th>
                    <th>État</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% catways.forEach(function(cat) { %>
                    <tr>
                        <td><%= cat.catwayNumber %></td>
                        <td><%= cat.catwayType %></td>
                        <td id="cell-<%= cat._id %>">
                            <span id="text-<%= cat._id %>"><%= cat.catwayState %></span>
                            <a onclick="toggleEdit('<%= cat._id %>')" class="btn btn-ok">Modifier</a>
                        </td>
                        <td>
                            <a href="/catways/delete/<%= cat._id %>" onclick="return confirm('Confirmer la suppression ?')" class="btn btn-cancel">Supprimer</a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </main>

    <footer><a href="/dashboard">← Retour au Dashboard</a></footer>

    <script src="/javascripts/inline-edit.js"></script>
</body>
</html>