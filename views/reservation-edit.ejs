<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Modifier la Réservation</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <header><h1>Modifier la Réservation</h1></header>
    <main class="catway-container">
        <section class="add-section">
            <h3>Modification</h3>
            <% if (locals.error && error) { %>
                <div class="error-message"><%= error %></div>
            <% } %>
            <form action="/reservations/update/<%= reservation._id %>" method="POST">
                <label>N° Catway :</label>
                <input type="number" name="catwayNumber" value="<%= reservation.catwayNumber %>" readonly>
                <input type="text" name="clientName" value="<%= reservation.clientName %>" required>
                <input type="text" name="boatName" value="<%= reservation.boatName %>" required>
                <input type="date" name="startDate" value="<%= reservation.startDate ? reservation.startDate.toISOString().split('T')[0] : '' %>" required>
                <input type="date" name="endDate" value="<%= reservation.endDate ? reservation.endDate.toISOString().split('T')[0] : '' %>" required>
                <div>
                    <button type="submit" class="btn btn-ok">Enregistrer</button>
                    <a href="/reservations" class="btn btn-cancel">Annuler</a>
                </div>
            </form>
        </section>

        <section class="related-reservations">
            <h4>Autres réservations sur ce Catway n°<%= reservation.catwayNumber %> :</h4>
            <ul>
                <% relatedReservations.forEach(function(res) { %>
                    <li>
                        <%= res.clientName %> : <%= res.startDate ? res.startDate.toLocaleDateString() : 'N/A' %> au <%= res.endDate ? res.endDate.toLocaleDateString() : 'N/A' %>
                        <% if (res._id.toString() === reservation._id.toString()) { %> <strong>(Actuelle)</strong> <% } %>
                    </li>
                <% }); %>
            </ul>
        </section>
    </main>
    <footer><a href="/dashboard">← Retour au Dashboard</a></footer>
</body>
</html>